{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mineradio Tauri Rewrite",
  "version": "0.1.0",
  "identifier": "com.mineradio.fork.tauri",
  "build": {
    "beforeDevCommand": "bun run --filter @mineradio/web dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "bun run --filter @mineradio/web build && bun run --filter @mineradio/desktop build:sidecar",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Mineradio Tauri Rewrite",
        "width": 1280,
        "height": 720,
        "minWidth": 960,
        "minHeight": 540
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "category": "Music",
    "externalBin": [
      "binaries/mineradio-sidecar-api"
    ],
    "icon": [
      "icons/icon.ico"
    ],
    "shortDescription": "Mineradio Tauri rewrite shell",
    "longDescription": "A GPL-3.0 Tauri rewrite shell for Mineradio.",
    "windows": {
      "allowDowngrades": false,
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "languages": [
          "SimpChinese",
          "English"
        ],
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/zzstar101/Mineradio/releases/latest/download/latest.json"
      ],
      "pubkey": ""
    }
  }
}
